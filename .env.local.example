# .env.local.example — copy to .env.local (gitignored) and adjust.
#
# The build wrapper scripts source .env.local before invoking Packer.
# Variables here are forwarded as PKR_VAR_* env vars to Packer. Anything
# not set falls back to the defaults declared in the per-OS
# variables.pkr.hcl.

# ---- Ubuntu 24.04 ARM64 -----------------------------------------------------

# Ubuntu Server 24.04 ARM64 live ISO. The build wrapper downloads to
# packer/ubuntu-24-04-arm64/packer_cache/iso/ and verifies SHA256 against the
# upstream SHA256SUMS before handing the local path to Packer.
# Default: 24.04.4 from cdimage.ubuntu.com (ARM64 ISOs aren't on
# releases.ubuntu.com — that mirror is amd64-only).
# UBUNTU_ISO_URL=https://cdimage.ubuntu.com/releases/24.04/release/ubuntu-24.04.4-live-server-arm64.iso
# UBUNTU_ISO_SHA256SUMS_URL=https://cdimage.ubuntu.com/releases/24.04/release/SHA256SUMS

# Build VM resources.
# UBUNTU_CPU_COUNT=2
# UBUNTU_MEMORY_GB=8
# UBUNTU_DISK_SIZE_GB=60

# Output image name in ~/.tart/vms/.
# UBUNTU_VM_NAME=ubuntu-24-04-arm64-base

# ---- Windows 11 ARM64 -------------------------------------------------------

# Path to the Microsoft Windows 11 ARM64 ISO. Download from
# https://www.microsoft.com/software-download/windows11arm64 — Microsoft
# does not permit redistribution, so this must be supplied locally. See
# packer/windows-11-arm64/README.md for the download steps.
# WINDOWS_ISO_PATH=/Users/you/Downloads/Win11_24H2_English_Arm64.iso

# Optional SHA256 of the ISO above. The download page lists it next to the
# file; if set, the wrapper verifies before invoking Packer. If unset, the
# wrapper warns and continues without verification.
# The hash below matches the public 24H2 English ARM64 ISO as of 2026-05.
# WINDOWS_ISO_SHA256=57d1dfb2c6690a99fe99226540333c6c97d3fd2b557a50dfe3d68c3f675ef2b0

# Path to virtio-win.iso (Microsoft-signed virtio drivers). Required for
# Win11 ARM Setup to see the disk — WinPE has no in-box drivers for the
# storage controllers QEMU emulates. Download from:
#   https://fedorapeople.org/groups/virt/virtio-win/direct-downloads/stable-virtio/virtio-win.iso
# Recent releases include arm64 binaries; older ones are x86_64 only.
# VIRTIO_WIN_ISO_PATH=/Users/you/Downloads/virtio-win.iso

# Build VM resources.
# WINDOWS_CPU_COUNT=4
# WINDOWS_MEMORY_GB=16
# WINDOWS_DISK_SIZE_GB=100

# Output image name in ~/.tart/vms/.
# WINDOWS_VM_NAME=windows-11-arm64-base
