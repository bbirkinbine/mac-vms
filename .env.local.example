# .env.local.example — copy to .env.local (gitignored) and adjust.
#
# The build wrapper scripts source .env.local before invoking Packer.
# Variables here are forwarded as PKR_VAR_* env vars to Packer. Anything
# not set falls back to the defaults declared in the per-OS
# variables.pkr.hcl.

# ---- Ubuntu 24.04 ARM64 -----------------------------------------------------

# Ubuntu Server 24.04 ARM64 ISO. Override to pin a specific point release.
# Default: latest 24.04.x from releases.ubuntu.com.
# UBUNTU_ISO_URL=https://releases.ubuntu.com/24.04/ubuntu-24.04.1-live-server-arm64.iso
# UBUNTU_ISO_CHECKSUM=sha256:...

# Build VM resources.
# UBUNTU_CPU_COUNT=4
# UBUNTU_MEMORY_GB=8
# UBUNTU_DISK_SIZE_GB=40

# Output image name in ~/.tart/vms/.
# UBUNTU_VM_NAME=ubuntu-24-04-arm64-base

# ---- Windows 11 ARM64 -------------------------------------------------------

# Path to the Microsoft Windows 11 ARM64 VHDX. Download from the Windows
# Insider Preview page — Microsoft does not permit redistribution, so this
# must be supplied locally. See packer/windows-11-arm64/README.md.
# WINDOWS_VHDX_PATH=/Users/you/Downloads/Windows11_InsiderPreview_Client_ARM64.vhdx

# Build VM resources.
# WINDOWS_CPU_COUNT=4
# WINDOWS_MEMORY_GB=8
# WINDOWS_DISK_SIZE_GB=64

# Output image name in ~/.tart/vms/.
# WINDOWS_VM_NAME=windows-11-arm64-base
