<?xml version="1.0" encoding="utf-8"?>
<!--
  Autounattend.xml — Windows 11 ARM64 unattended install for Tart + Packer.

  Delivered to Setup as a second attached ISO built by scripts/build-windows.sh
  (the wrapper repacks {http/Autounattend.xml} into a tiny CIDATA-style ISO and
  hands its path to Packer via PKR_VAR_unattend_iso_path; the source attaches
  both the Windows install ISO and this unattend ISO via `from_iso`). Windows
  Setup probes attached removable media for `Autounattend.xml` at the root
  and applies it before the language picker.

  Schema is identical to x86 but every component carries
  processorArchitecture="arm64". The homelab x86 file
  (homelab/packer/windows-11-base/http/Autounattend.xml) is the reference,
  but several sections are deliberately not copied — see CLAUDE.md
  "What NOT to lift from homelab".

  Build-time AdministratorPassword and FirstLogonCommands.WinRM-bootstrap
  must stay in sync with variables.pkr.hcl/var.build_password. If you change
  one, change the other.

  References:
    - Microsoft answer file reference:
      https://learn.microsoft.com/en-us/windows-hardware/customize/desktop/unattend/
    - Homelab x86 sibling (for FirstLogonCommands recipe):
      ~/Downloads/src/homelab/packer/windows-11-base/http/Autounattend.xml
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- =========================================================================
       windowsPE pass: locale, storage / partitioning, image selection.

       Note on driver injection: Win11 ARM's WinPE doesn't ship in-box
       drivers for QEMU's emulated storage. We solve this by bundling
       Microsoft-signed virtio drivers (viostor / vioscsi / NetKVM) into
       the same CD that carries this Autounattend.xml — scripts/build-
       windows.sh extracts them from virtio-win.iso into ./drivers/staging/
       and Packer's `cd_files` packs them into the unattend CD as
       /drivers/staging/<driver>/. The PnpCustomizationsWinPE block below
       references those drivers via multiple candidate drive letters,
       because WinPE's enumeration order under ARM64 + EFI + QEMU is
       non-deterministic (install ISO, unattend CD, and virtio-win.iso are
       all attached at qemu launch; the unattend CD typically lands at D:,
       E:, or F: but we don't predict it).
       ========================================================================= -->
  <settings pass="windowsPE">

    <component name="Microsoft-Windows-PnpCustomizationsWinPE" processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <DriverPaths>
        <!-- viostor: virtio-blk driver. Without this, WinPE can't see the
             boot disk (Packer's default disk_interface is virtio). We
             list D:, E:, F:, G: as candidates for the unattend CD's
             dynamically-assigned drive letter; WinPE silently ignores
             paths that don't resolve and loads the driver from whichever
             one does. -->
        <PathAndCredentials wcm:action="add" wcm:keyValue="viostor-d">
          <Path>D:\drivers\staging\viostor</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="viostor-e">
          <Path>E:\drivers\staging\viostor</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="viostor-f">
          <Path>F:\drivers\staging\viostor</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="viostor-g">
          <Path>G:\drivers\staging\viostor</Path>
        </PathAndCredentials>

        <!-- vioscsi: virtio-scsi driver. Not strictly required at install
             time (disk_interface=virtio uses virtio-blk → viostor), but
             cheap to ship alongside in case we ever swap the bus or a
             second virtio-scsi disk is attached. -->
        <PathAndCredentials wcm:action="add" wcm:keyValue="vioscsi-d">
          <Path>D:\drivers\staging\vioscsi</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="vioscsi-e">
          <Path>E:\drivers\staging\vioscsi</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="vioscsi-f">
          <Path>F:\drivers\staging\vioscsi</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="vioscsi-g">
          <Path>G:\drivers\staging\vioscsi</Path>
        </PathAndCredentials>

        <!-- NetKVM: virtio-net driver. Without this, the FirstLogonCommands
             step that waits for the NIC sits there forever and WinRM
             never comes up. -->
        <PathAndCredentials wcm:action="add" wcm:keyValue="NetKVM-d">
          <Path>D:\drivers\staging\NetKVM</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="NetKVM-e">
          <Path>E:\drivers\staging\NetKVM</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="NetKVM-f">
          <Path>F:\drivers\staging\NetKVM</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="NetKVM-g">
          <Path>G:\drivers\staging\NetKVM</Path>
        </PathAndCredentials>
      </DriverPaths>
    </component>

    <component name="Microsoft-Windows-International-Core-WinPE" processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup" processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <!-- Pure-UEFI disk layout for ARM64: ESP + MSR + Windows. The 300MB
           ESP is generous (Microsoft minimum is 100MB) so future feature
           updates that bloat the recovery partition have headroom. -->
      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>300</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>FAT32</Format>
              <Label>System</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <!-- Multi-edition ISO: pick Pro by image name. If 24H2 ARM64 uses a
           different SKU label (e.g. "Windows 11 Pro for ARM"), the install
           halts with "the image you have selected is not for this type of
           computer" — re-check with `dism /Get-WimInfo` and update. -->
      <ImageInstall>
        <OSImage>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>Windows 11 Pro</Value>
            </MetaData>
          </InstallFrom>
        </OSImage>
      </ImageInstall>

      <UserData>
        <AcceptEula>true</AcceptEula>
        <FullName>mac-vms-build</FullName>
        <Organization>mac-vms</Organization>
        <!-- Generic install key for Windows 11 Pro. Permits Setup to
             complete without prompting; does NOT activate. Activation is a
             downstream concern (real key via cloud-init, MAK injection,
             or just live with the watermark in lab use). -->
        <ProductKey>
          <Key>VK7JG-NPHTM-C97JM-9MPGT-3V66T</Key>
          <WillShowUI>OnError</WillShowUI>
        </ProductKey>
      </UserData>

      <!-- LabConfig bypass for Win11 hardware-requirements checks.
           Required even though swtpm provides a real TPM 2.0 and edk2
           provides UEFI Secure Boot, because `cpu host` advertises Apple
           Silicon to the guest and Apple Silicon isn't on Microsoft's
           Win11-supported CPU list. Without BypassCPUCheck, ARM64 24H2
           Setup halts with "This PC doesn't currently meet Windows 11
           system requirements" right after the product-key step. The
           remaining four bypasses are belt-and-braces — TPM/SecureBoot
           checks actually do pass on our platform, but enumerating them
           costs nothing and protects against a future Setup version
           tightening any single check.

           Mirrors the homelab x86 build's RunSynchronous block (which
           uses these same reg keys for the same reason — Proxmox
           virtualised CPUs aren't on the list either). RunSynchronous
           in the windowsPE pass runs strictly before Setup's hardware
           probe, which is the only place the bypass is honoured. -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassStorageCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>

  <!-- =========================================================================
       specialize pass: computer name, locale persistence after install.
       ========================================================================= -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <!-- NetBIOS computer name limit is 15 chars; the previous
           "windows-11-arm64" (16 chars) made Setup fail the specialize
           pass with hrResult=0x80220005 "Value is invalid" even though
           xmllint and packer validate were both green — the rule is
           enforced inside Microsoft-Windows-Shell-Setup's schema, not
           XML-structurally. -->
      <ComputerName>win11-arm64</ComputerName>
      <TimeZone>UTC</TimeZone>
      <!-- Skip the cloud-account requirement that 24H2 introduced. -->
      <RegisteredOrganization>mac-vms</RegisteredOrganization>
      <RegisteredOwner>mac-vms-build</RegisteredOwner>
    </component>
    <component name="Microsoft-Windows-International-Core" processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>
  </settings>

  <!-- =========================================================================
       oobeSystem pass: skip OOBE, create build user, autologon once,
       run FirstLogonCommands to bring up WinRM.
       ========================================================================= -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <!-- Bypasses the Microsoft account requirement on Win11 24H2. If a
             future Windows version blocks this too, splice in BYPASSNRO
             registry writes via RunSynchronous in specialize. -->
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Work</NetworkLocation>
        <ProtectYourPC>3</ProtectYourPC>
        <SkipUserOOBE>true</SkipUserOOBE>
        <SkipMachineOOBE>true</SkipMachineOOBE>
      </OOBE>

      <UserAccounts>
        <AdministratorPassword>
          <!-- MUST match var.build_password in variables.pkr.hcl. Rotated
               to 32-byte random + account disabled by PackerBuildCleanup
               scheduled task on first boot of any clone — see
               provision/99-sysprep.ps1. -->
          <Value>packer-build-only-Win11!</Value>
          <PlainText>true</PlainText>
        </AdministratorPassword>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>Administrator</Name>
            <Group>Administrators</Group>
            <Password>
              <Value>packer-build-only-Win11!</Value>
              <PlainText>true</PlainText>
            </Password>
            <Description>Local admin used by Packer build pipeline. Rotated + disabled by PackerBuildCleanup on first clone boot.</Description>
            <DisplayName>Administrator</DisplayName>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <!-- LogonCount=1: the build needs exactly one auto-login (the first
           OOBE boot, where FirstLogonCommands sets up WinRM). Windows
           decrements the count to 0 and disables AutoAdminLogon itself
           after that single use, so the registry values that survive
           sysprep are already cleared on the build VM. The cleanup
           scheduled task still wipes them on each clone for defense in
           depth. -->
      <AutoLogon>
        <Username>Administrator</Username>
        <Password>
          <Value>packer-build-only-Win11!</Value>
          <PlainText>true</PlainText>
        </Password>
        <Enabled>true</Enabled>
        <LogonCount>1</LogonCount>
      </AutoLogon>

      <!-- Bring up WinRM so Packer's provisioner pipeline can connect.

           Order is load-bearing:
             1. Install ARM64 virtio drivers into the running OS's driver
                store. WinPE injection (via PnpCustomizationsWinPE above)
                gets viostor onto the boot path — without that the OS
                can't even boot from the disk — but NetKVM does NOT
                survive into the installed system, because the installed
                Windows boots fresh from install.wim with whatever drivers
                that WIM carries. install.wim has no ARM64 virtio NIC
                driver, so the NIC has no driver here until pnputil
                registers one. The unattend CD is still attached on first
                boot; drive letters in the running OS aren't the same as
                the WinPE phase's, so we scan D:..I: for the staging tree.
             2. Wait for the NIC to attach and complete DHCP. Now that
                NetKVM is registered, the virtio-net device gets a driver
                bind, Windows starts the adapter, and DHCP fires.
                Get-NetConnectionProfile may briefly return nothing while
                the network category is being assigned.
             3. Force the network category to Private. AllowUnencrypted
                refuses to apply on the Public profile (error 0x80338169
                regardless of firewall rules, even with NetworkLocation=Work
                in OOBE — Windows 24H2 quirk).
             4. Enable WinRM service.
             5. Configure WinRM listener (Basic + AllowUnencrypted, now
                permitted because we are Private).
             6. Open firewall port 5985 on all profiles.
             7. Disable wuauserv so Windows Update doesn't try to download
                during the build window. -->
      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Description>Install ARM64 virtio drivers into the running OS driver store</Description>
          <CommandLine>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference='Stop'; $found=$false; foreach ($l in 'D','E','F','G','H','I') { $p = ${l} + ':\drivers\staging'; if (Test-Path $p) { Get-ChildItem -Path $p -Recurse -Filter *.inf | ForEach-Object { pnputil.exe /add-driver $_.FullName /install | Out-Null }; $found=$true; break } }; if (-not $found) { Write-Error 'drivers\staging not found on D:..I: — unattend CD missing or relocated' }"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Description>Wait for network and force profile to Private</Description>
          <CommandLine>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "for ($i=0; $i -lt 60; $i++) { $p = Get-NetConnectionProfile -ErrorAction SilentlyContinue; if ($p) { break }; Start-Sleep 2 }; Get-NetConnectionProfile | Set-NetConnectionProfile -NetworkCategory Private"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Description>Enable WinRM service</Description>
          <CommandLine>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Set-Service -Name WinRM -StartupType Automatic; Start-Service WinRM"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Description>Configure WinRM listener and auth</Description>
          <CommandLine>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "winrm quickconfig -quiet; winrm set winrm/config/service '@{AllowUnencrypted=\"true\"}'; winrm set winrm/config/service/auth '@{Basic=\"true\"}'"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Description>Open firewall for WinRM</Description>
          <CommandLine>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "New-NetFirewallRule -Name 'WinRM HTTP-In' -DisplayName 'WinRM HTTP-In' -Profile Any -LocalPort 5985 -Protocol TCP -Action Allow"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Description>Disable Windows Update during build window</Description>
          <CommandLine>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Set-Service -Name wuauserv -StartupType Disabled; Stop-Service wuauserv -Force"</CommandLine>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>
</unattend>
