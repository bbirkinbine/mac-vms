.DS_Store
.claude/

# Local credentials — never commit. Whitelist the .example template only.
.env
.env.*
!.env.*.example

# Packer
packer_cache/
*.box
crash.log
crash.*.log

# Build artifacts
output-*/
*.tart

# virtio-win ARM64 driver staging tree, extracted from virtio-win.iso at
# build time by scripts/build-windows.sh. The drivers/ directory itself is
# tracked (with .gitkeep + README.md) so cd_files paths resolve at packer-
# validate time even without a build run.
packer/windows-11-arm64/drivers/staging/

# Real seed YAMLs contain SSH pubkeys, hashes, etc. — never commit.
# Whitelist the .example.yaml template only, same pattern as .env.*.
packer/*/seed/*.yaml
!packer/*/seed/*.example.yaml

# Downloaded installer media — large, redistributable only sometimes (Windows
# ARM64 ISO from Microsoft is bring-your-own; Ubuntu ISO is fine to re-fetch).
*.iso
*.vhdx
*.vhd
